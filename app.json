{
  "expo": {
    "name": "LifeMate",
    "slug": "lifeMate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/lifemate-icon.png",
    "scheme": "lifemate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.itishree.lifemate"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-lifemate.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a61ed20b-44ef-4ec4-9f88-0f3d64dbc905"
      }
    },
    "owner": "iti_shree"
  }
}
